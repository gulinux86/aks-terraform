# Local .terraform directories
**/.terraform/*
plan

# Provider lock files SHOULD be committed for reproducible builds across CI and
# local runs — do NOT ignore .terraform.lock.hcl.

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data. These
# should not be in version control.
*.tfvars
*.tfvars.json

# ...except the per-environment tfvars, which hold only non-sensitive inputs
# (CIDR, location, project name, tags) and are required by the CI pipeline.
!**/environments/**/*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Tooling local (not part of the delivered infra)
.claude/
openspec/
